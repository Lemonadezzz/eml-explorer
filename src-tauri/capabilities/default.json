{
  "$schema": "../gen/schemas/desktop-capability.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "fs:allow-read",
    "fs:allow-exists",
    "fs:read-all",
    "opener:allow-open-path",
    "opener:default"
  ]
}